<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="end"
    android:orientation="vertical"
    android:paddingTop="12dp"
    android:paddingBottom="12dp"
    android:paddingStart="20dp"
    android:paddingEnd="20dp">

    <!-- TEXT -->
    <LinearLayout
        android:id="@+id/layoutText"
        android:layout_width="wrap_content"
        android:maxWidth="400dp"
        android:layout_height="wrap_content"
        android:background="@drawable/vc_chatbubbleoutgoing"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/txtMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/color_kia_black"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/txtFileName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:textColor="@color/color_kia_black"
            android:textSize="15sp" />
    </LinearLayout>

    <!-- FILE -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/layoutFileContainer"
        android:layout_width="wrap_content"
        android:maxWidth="420dp"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:shapeAppearanceOverlay="@style/CardShapeoutgoing"
        android:descendantFocusability="blocksDescendants"
        android:focusable="false"
        android:focusableInTouchMode="false"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end"
                android:paddingTop="4dp"
                android:paddingEnd="4dp">
                <ImageView
                    android:id="@+id/btnFileOverflow"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="6dp"
                    android:padding="5dp"
                    android:background="@drawable/bg_rounded_circle"
                    android:src="@drawable/download_minimalistic_svgrepo_com"
                    android:backgroundTint="#DDDDDD"  />
            </LinearLayout>

            <ImageView
                android:id="@+id/imgFileThumbnail"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:visibility="gone"
                android:scaleType="centerCrop"
                android:contentDescription="@null" />

            <LinearLayout
                android:layout_width="180dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:minWidth="180dp">

                <ImageView
                    android:id="@+id/imgFileIcon"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/file_pdf_icon"
                    android:contentDescription="@null"
                    android:padding="8dp" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/txtFileTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="middle"
                        android:maxLines="2"
                        android:textColor="@color/color_kia_black"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/txtFileSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="PDF"
                        android:textColor="@color/grey_text_color"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>
            <TextView
                android:id="@+id/txtFileCaption"
                android:layout_width="180dp"
                android:layout_height="wrap_content"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="4dp"
                android:paddingBottom="8dp"
                android:visibility="gone"
                android:maxLines="4"
                android:gravity="start"
                android:textColor="@color/color_kia_black"
                android:textSize="12sp" />

            <LinearLayout
                android:id="@+id/layoutFileError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_white_rounded"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="4dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Upload failed"
                    android:textColor="@color/red"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/btnFileRetry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="Retry"
                    android:textColor="@color/black"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
        <!-- SAME CONTENT (UNCHANGED) -->
        <!-- COPY your full inner layout here EXACTLY -->

    </com.google.android.material.card.MaterialCardView>

    <!-- IMAGE -->
    <LinearLayout
        android:id="@+id/layoutImageContainer"
        android:layout_width="240dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/vc_chatbubbleoutgoing"
        android:padding="10dp"
        android:descendantFocusability="blocksDescendants"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:backgroundTint="@color/white"
        android:visibility="visible">



        <com.google.android.material.card.MaterialCardView
            android:layout_width="220dp"
            android:layout_height="220dp"
            app:strokeWidth="0dp"
            app:cardCornerRadius="14dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/imgAttachment"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitXY" />

                <ProgressBar
                    android:id="@+id/mediaLoader"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"/>

                <ImageView
                    android:id="@+id/btnImageOverflow"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_alignParentEnd="true"
                    android:layout_alignParentTop="true"
                    android:layout_margin="6dp"
                    android:padding="5dp"
                    android:background="@drawable/bg_rounded_circle"
                    android:src="@drawable/download_minimalistic_svgrepo_com"
                    android:backgroundTint="#DDDDDD"  />

                <ImageView
                    android:id="@+id/imgPlayVideo"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_centerInParent="true"
                    android:src="@drawable/play_circle"
                    android:visibility="gone"
                    app:tint="@color/white" />

                <LinearLayout
                    android:id="@+id/layoutUploadProgress"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#66000000"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <ProgressBar
                        android:id="@+id/progressUpload"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:indeterminate="false"
                        android:max="100"
                        android:progress="0" />

                    <TextView
                        android:id="@+id/txtUploadPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="0%"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>


                <!-- Error Overlay -->
                <LinearLayout
                    android:id="@+id/layoutError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_alignTop="@id/imgAttachment"
                    android:layout_alignBottom="@id/imgAttachment"
                    android:background="#80000000"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/ic_error"
                        android:padding="4dp"
                        android:text="Error"
                        android:textColor="@color/white"
                        android:textSize="10sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_white_rounded"
                        android:padding="4dp"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Upload failed"
                            android:textColor="@color/red"
                            android:textSize="10sp"/>
                        <TextView
                            android:id="@+id/btnRetry"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="Retry"
                            android:textColor="@color/black"
                            android:textStyle="bold"
                            android:textSize="10sp"/>
                    </LinearLayout>
                </LinearLayout>
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>
        <TextView
            android:id="@+id/txtImageCaption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:visibility="visible"
            android:textColor="@color/color_kia_black"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- VOICE -->
    <LinearLayout
        android:id="@+id/layoutVoice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:descendantFocusability="blocksDescendants"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:orientation="horizontal"
        android:background="@drawable/vc_chatbubbleoutgoing"
        android:padding="14dp">
        <ImageView
            android:background="@drawable/bg_small_cornerradius"
            android:id="@+id/imgrecordTablet"
            android:layout_width="@dimen/_15sdp"
            android:layout_height="@dimen/_15sdp"
            android:padding="@dimen/_3sdp"
            android:layout_gravity="center"
            android:src="@drawable/mic__2_"
            />
        <TextView
            android:id="@+id/txtVoiceDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="00:12"
            android:layout_gravity="center"
            android:textColor="@color/color_kia_black"
            android:textSize="13sp" />
        <com.masoudss.lib.WaveformSeekBar
            android:id="@+id/waveformView"
            android:layout_width="80dp"
            android:layout_height="40dp"
            android:layout_marginStart="16dp"
            />
        <ImageView
            android:id="@+id/btnPlayVoice"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:layout_marginStart="8dp"
            android:src="@drawable/play_circle"
            android:contentDescription="@null" />

        <!-- SAME CONTENT -->
    </LinearLayout>

    <!-- TIME -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:descendantFocusability="blocksDescendants"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/txtTime"
            android:textSize="12sp" />

        <ImageView
            android:id="@+id/imgStatus"
            android:layout_width="16dp"
            android:layout_height="16dp" />
    </LinearLayout>

</LinearLayout>