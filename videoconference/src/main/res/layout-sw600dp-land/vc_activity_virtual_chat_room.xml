<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/bg_message_screen">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="@dimen/_5sdp"
        android:id="@+id/backLayout"
        android:layout_gravity="center"
        android:background="#F9F9F9"
        app:layout_constraintTop_toTopOf="parent"
        android:orientation="horizontal">


        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/btnBack"
            android:padding="@dimen/_5sdp"
            android:layout_width="@dimen/_25sdp"
            android:layout_height="@dimen/_25sdp"
            android:layout_gravity="center|center_horizontal"
            android:src="@drawable/keyboard_arrow_down__1_" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/repairordertv"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="Back to Home"
            android:textColor="@color/black"
            android:fontFamily="@font/kia_signature_fix_bold"
            android:textSize="18sp"/>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <androidx.appcompat.widget.AppCompatImageView
            android:layout_width="@dimen/_35sdp"
            android:layout_height="@dimen/_15sdp"
            android:layout_marginEnd="@dimen/_25sdp"
            android:layout_gravity="center|center_horizontal"
            android:src="@drawable/layer1" />




    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:id="@+id/line"
        app:layout_constraintTop_toBottomOf="@+id/tabSwitcher"
        android:background="@color/grey"/>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">




    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="1dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- Left panel -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/white"
            android:orientation="vertical"
            >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center_vertical"
                android:padding="@dimen/_5sdp"
                >

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/homeTv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Media"
                    android:fontFamily="@font/kia_signature_fix_regular"
                    android:textSize="16sp"
                    android:layout_gravity="center_vertical"
                    android:textColor="#101010"
                    android:textStyle="bold"
                    />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/homeIcon"
                    android:layout_width="@dimen/_10sdp"
                    android:layout_height="@dimen/_10sdp"
                    android:layout_gravity="center|center_horizontal"
                    android:src="@drawable/keyboard_arrow_down__2_" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/chatRoomtv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chat Room"
                    android:fontFamily="@font/kia_signature_fix_bold"
                    android:textSize="16sp"
                    android:textFontWeight="800"
                    android:layout_gravity="center_vertical"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    />









            </LinearLayout>
            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                app:layout_constraintTop_toBottomOf="@+id/tabSwitcher"
                android:background="@color/grey"/>


            <LinearLayout
                android:paddingHorizontal="@dimen/_5sdp"
                android:layout_gravity="center"
                android:paddingVertical="@dimen/_4sdp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtInitial"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:text=""
                    android:layout_gravity="center"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:background="@drawable/bg_rounded_circle"
                    android:fontFamily="@font/kia_signature_fix_bold"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="10dp">

                    <TextView
                        android:id="@+id/txtLeftCustomerName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lata"
                        android:textSize="18sp"
                        android:textColor="@color/black"
                        android:fontFamily="@font/kia_signature_fix_bold"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:id="@+id/txtLeftRoNumber"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:letterSpacing="0.1"
                            android:text="RO R202401012"
                            android:textColor="@color/grey_text_color"
                            android:fontFamily="@font/kia_signature_fix_bold"
                            android:textSize="12sp"/>


                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1"/>

                        <TextView
                            android:id="@+id/txtLeftStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/vc_bg_status_chip"
                            android:layout_gravity="center"
                            android:text="Open"
                            android:paddingVertical="@dimen/_2sdp"
                            android:paddingHorizontal="@dimen/_5sdp"
                            android:fontFamily="@font/kia_signature_fix_regular"
                            android:textColor="@color/white"
                            android:textSize="12sp" />


                    </LinearLayout>


                </LinearLayout>




            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                app:layout_constraintTop_toBottomOf="@+id/tabSwitcher"
                android:background="@color/grey"/>





            <!-- Tabs -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@+id/repairOrderLayout1"
                app:layout_constraintStart_toStartOf="parent"
                android:id="@+id/tabSwitcher"
                android:padding="@dimen/_5sdp"
                android:gravity="center"
                android:orientation="horizontal">


                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tabRoDetails"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/roDetails"
                    android:layout_marginStart="@dimen/_5sdp"
                    android:fontFamily="@font/kia_signature_fix_bold"
                    android:textSize="14sp"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tabParticipants"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/participants"
                    android:layout_marginStart="@dimen/_5sdp"
                    android:fontFamily="@font/kia_signature_fix_bold"
                    android:textSize="14sp"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    />



                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tabMedia"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Media"
                    android:layout_marginStart="@dimen/_5sdp"
                    android:fontFamily="@font/kia_signature_fix_regular"
                    android:textSize="14sp"
                    android:textColor="#343434"
                    android:textStyle="bold"
                    />



            </LinearLayout>

            <View
                android:id="@+id/tabIndicator"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:background="@color/colorPrimary_kia_kandid"
                />


            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:id="@+id/line1"
                android:background="@color/grey"/>


            <FrameLayout
                android:id="@+id/FragmentContainer"
                android:layout_width="match_parent"
                android:layout_marginTop="@dimen/_2sdp"
                android:layout_weight="1"
                app:layout_constraintTop_toBottomOf="@+id/line"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_height="0dp" />

            <!-- Simple RO details on left -->
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/grey"/>

        <!-- Right panel -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2"
            android:orientation="vertical"
            android:background="@color/bg_message_screen">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/_5sdp"
                android:paddingVertical="@dimen/_5sdp">

            <include
                android:id="@+id/includeNetworkErrorBanner"
                layout="@layout/vc_layout_network_error_banner" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:background="@color/bg_message_screen"
                android:layout_weight="1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/layoutPinnedStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/vc_bg_pinned"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="10dp"
                        android:visibility="gone">

                        <ImageView
                            android:id="@+id/imgPin"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:src="@drawable/ic_pin"
                            android:layout_marginEnd="10dp"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/txtStatusLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Status"
                                android:textSize="11sp"
                                android:textColor="@color/black"
                                android:alpha="0.8"/>

                            <TextView
                                android:id="@+id/txtPinnedLifecycle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Appointment Confirmed"
                                android:textStyle="bold"
                                android:textSize="14sp"
                                android:textColor="@color/black"/>
                        </LinearLayout>

                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerMessages"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:scrollbars="vertical"

                        android:overScrollMode="never"
                        android:descendantFocusability="blocksDescendants"/>
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressLoadingMessages"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:visibility="gone" />

                <ProgressBar
                    android:id="@+id/progressLoadingOlderMessages"
                    style="?android:attr/progressBarStyleSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|center_horizontal"
                    android:layout_marginTop="8dp"
                    android:visibility="gone" />

                <!-- In-place media preview (replaces chat when visible) -->
                <FrameLayout
                    android:id="@+id/layoutPreviewContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:visibility="gone"
                    android:background="@android:color/transparent">
                    <include
                        android:id="@+id/includePreviewContent"
                        layout="@layout/vc_layout_media_preview" />
                </FrameLayout>
            </FrameLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutTypingIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginBottom="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView
                    android:id="@+id/txtTypingInitial"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_rounded_circle"
                    android:gravity="center"
                    android:text="U"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/vc_bg_chat_bubble_incoming"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/txtTypingName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="User"
                        android:textColor="@color/black"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtTypingIndicator"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="is typing..."
                        android:textColor="@color/grey_text_color"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:layout_marginTop="8dp"
                android:background="@color/grey"/>

            <!-- Bottom unified container (hidden when preview is visible) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardViewBottomChat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="0dp"
                android:backgroundTint="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Quick Replies (inside same box) -->
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingStart="12dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="4dp"
                        android:scrollbars="none">

                        <LinearLayout
                            android:padding="@dimen/_5sdp"
                            android:id="@+id/quickReplyContainerTablet"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal" />

                    </HorizontalScrollView>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:background="@color/grey"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/_5sdp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:paddingHorizontal="@dimen/_5sdp"
                            android:paddingVertical="@dimen/_5sdp"
                            android:background="@drawable/bg_comment_box"
                            android:backgroundTint="#F7F7F7"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                        <EditText
                            android:id="@+id/edtMessageTablet"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/kia_signature_fix_regular"
                            android:hint="Text here"
                            android:textSize="14sp"
                            android:background="@null"
                            android:textColor="@color/black"
                            android:inputType="textMultiLine"
                            android:maxLines="4"
                            android:minLines="1"
                            android:scrollbars="vertical"
                            android:gravity="center_vertical"
                            />

                        <ImageView
                            android:id="@+id/imgAttachmentTablet"
                            android:layout_width="@dimen/_12sdp"
                            android:layout_height="@dimen/_12sdp"
                            android:layout_marginStart="8dp"
                            android:layout_gravity="center_vertical"
                            android:visibility="visible"
                            android:src="@drawable/screen_share"
                           />

</LinearLayout>
                        <LinearLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:id="@+id/recordLayout"
                            android:layout_marginStart="8dp"
                            android:gravity="center"
                          >

                            <ImageView
                                android:background="@drawable/bg_small_cornerradius"
                                android:id="@+id/imgrecordTablet"
                                android:layout_width="@dimen/_15sdp"
                                android:layout_height="@dimen/_15sdp"
                                android:padding="@dimen/_3sdp"
                                android:src="@drawable/mic__2_"
                               />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="40dp"
                            android:id="@+id/sendLayout"
                            android:layout_height="40dp"
                            android:layout_marginStart="8dp"
                            android:visibility="gone"
                            android:gravity="center"
                            >

                            <ImageView
                                android:background="@drawable/bg_small_cornerradius"
                                android:id="@+id/imgSendTablet"
                                android:layout_width="@dimen/_15sdp"
                                android:layout_height="@dimen/_15sdp"
                                android:padding="@dimen/_3sdp"
                                android:src="@drawable/send"
                                />

                        </LinearLayout>

                    </LinearLayout>
                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </LinearLayout>
    </LinearLayout>
    </LinearLayout>

</layout>
