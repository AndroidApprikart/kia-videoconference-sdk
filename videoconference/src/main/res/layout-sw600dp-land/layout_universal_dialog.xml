<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    tools:ignore="MissingDefaultResource">

    <data>

    </data>

    <RelativeLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@color/white">
        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/white"
            android:padding="@dimen/_10sdp"
            android:theme="@style/Base.Theme.VideoConference">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tv_dialog_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:textColor="@color/color_kia_black"
                android:textSize="16sp"
                android:paddingBottom="@dimen/_3sdp"
                android:fontFamily="@font/kia_signature_fix_bold"/>

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/iv_dialog_logo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_below="@id/tv_dialog_title" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tv_dialog_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/iv_dialog_logo"
                android:layout_centerHorizontal="true"
                android:lines="2"
                android:maxLines="2"
                android:gravity="center"
                android:textColor="@color/color_kia_black"
                android:paddingBottom="@dimen/_3sdp"
                android:fontFamily="@font/kia_signature_fix_regular"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_below="@id/tv_dialog_message"
                android:gravity="center_horizontal"
                android:paddingTop="@dimen/_3sdp"
                android:layout_centerHorizontal="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_negative"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/kia_signature_fix_bold"
                    style="@style/OutlinedButtonStyle"
                    android:gravity="center"
                    android:layout_marginEnd="@dimen/_3sdp"
                    android:layout_gravity="center_horizontal"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_positive"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:layout_marginStart="@dimen/_3sdp"
                    android:layout_gravity="center_horizontal"/>
            </LinearLayout>
        </RelativeLayout>
    </RelativeLayout>

</layout>