<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white">

        <LinearLayout
            android:gravity="start"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:paddingVertical="@dimen/_5sdp"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">


            <TextView
                android:id="@+id/txtInitial"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="L"
                android:layout_gravity="center"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:background="@drawable/bg_rounded_circle"
                android:fontFamily="@font/kia_signature_fix_bold"/>

            <TextView
                android:id="@+id/tctParticipantName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="start"
                android:layout_gravity="center"
                android:text="Participant"
                android:textColor="#06141F"
                android:textSize="16sp"
                android:layout_marginStart="@dimen/_10sdp"
                android:fontFamily="@font/kia_signature_fix_bold"/>




            <TextView
                android:id="@+id/txtLeftStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/vc_bg_status_chip"
                android:layout_gravity="center"
                android:text="Open"
                android:layout_marginStart="@dimen/_5sdp"
                android:backgroundTint="#F2F2F2"
                android:paddingVertical="@dimen/_4sdp"
                android:paddingHorizontal="@dimen/_8sdp"
                android:fontFamily="@font/kia_signature_fix_regular"
                android:textColor="@color/black"
                android:textSize="12sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Change"
                android:id="@+id/change"
                android:layout_gravity="center"
                android:layout_marginEnd="@dimen/_5sdp"
                android:fontFamily="@font/kia_signature_fix_bold"
                android:textColor="@color/color_kia_black"
                android:background="@drawable/bg_kiablack_square"
                android:paddingHorizontal="@dimen/_10sdp"
                android:paddingVertical="@dimen/_5sdp"/>


        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>