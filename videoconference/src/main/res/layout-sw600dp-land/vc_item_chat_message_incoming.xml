<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="start"
    android:orientation="vertical"
    android:paddingTop="12dp"
    android:paddingBottom="12dp"
    android:paddingStart="20dp"
    android:paddingEnd="20dp">

    <!-- TEXT -->
    <LinearLayout
        android:id="@+id/layoutText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxWidth="600dp"
        android:background="@drawable/vc_bg_chat_bubble_outgoing"
        android:orientation="vertical"
        android:descendantFocusability="blocksDescendants"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:padding="16dp">

        <LinearLayout
            android:layout_marginBottom="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtSenderInitial"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_rounded_circle"
                android:gravity="center"
                android:text="U"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/txtSenderName"
                android:layout_marginStart="12dp"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/txtSenderRole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:background="@drawable/vc_bg_status_chip"
                android:text="SA"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:visibility="gone"
                />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/txtMessage"
            android:textColor="@color/color_kia_black"
            android:textSize="16sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/txtFileName"
            android:textColor="@color/color_kia_black"
            android:visibility="gone"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- FILE -->

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/layoutFileContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxWidth="440dp"
        android:visibility="gone"
        app:cardCornerRadius="14dp"
        android:descendantFocusability="blocksDescendants"
        android:focusable="false"
        android:focusableInTouchMode="false"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/layoutFileSenderRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="12dp"
                android:layout_marginBottom="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtFileSenderInitial"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_rounded_circle"
                    android:gravity="center"
                    android:text="U"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtFileSenderName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="User"
                    android:textColor="@color/black"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtFileSenderRole"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:background="@drawable/vc_bg_status_chip"
                    android:text="SA"
                    android:textColor="@color/white"
                    android:textSize="10sp"
                    android:visibility="gone" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end"
                android:paddingTop="4dp"
                android:paddingEnd="4dp">
                <ImageView
                    android:id="@+id/btnFileOverflow"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="6dp"
                    android:padding="5dp"
                    android:background="@drawable/bg_rounded_circle"
                    android:src="@drawable/download_minimalistic_svgrepo_com"
                    android:backgroundTint="#DDDDDD"/>
            </LinearLayout>
            <ImageView
                android:id="@+id/imgFileThumbnail"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:visibility="gone"
                android:scaleType="centerCrop"
                android:contentDescription="@null" />

            <LinearLayout
                android:layout_width="180dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:minWidth="180dp">

                <ImageView
                    android:id="@+id/imgFileIcon"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/file_pdf_icon"
                    android:contentDescription="@null"
                    android:padding="8dp" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/txtFileTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="middle"
                        android:maxLines="2"
                        android:textColor="@color/color_kia_black"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/txtFileSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="PDF"
                        android:textColor="@color/grey_text_color"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>
            <TextView
                android:id="@+id/txtFileCaption"
                android:layout_width="180dp"
                android:layout_height="wrap_content"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="4dp"
                android:paddingBottom="8dp"
                android:visibility="gone"
                android:maxLines="4"
                android:textColor="@color/color_kia_black"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- KEEP FULL ORIGINAL CONTENT SAME -->

    </com.google.android.material.card.MaterialCardView>

    <!-- IMAGE -->
    <LinearLayout
        android:id="@+id/layoutImageContainer"
        android:layout_width="240dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/vc_bg_chat_bubble_outgoing"
        android:padding="10dp"
        android:descendantFocusability="blocksDescendants"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/layoutMediaSenderRow"
            android:layout_marginBottom="8dp"
            android:layout_width="wrap_content"
            android:layout_marginTop="@dimen/_3sdp"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtMediaSenderInitial"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:textSize="13sp"
                android:textColor="@color/white"
                android:background="@drawable/bg_rounded_circle"
                android:gravity="center" />

            <TextView
                android:id="@+id/txtMediaSenderName"
                android:layout_marginStart="10dp"
                android:textSize="14sp"
                android:textColor="@color/black"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtMediaSenderRole"
                android:visibility="gone"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:background="@drawable/vc_bg_status_chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:layout_marginStart="8dp"
                android:textSize="11sp" />
        </LinearLayout>



        <com.google.android.material.card.MaterialCardView
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_gravity="center"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/imgAttachment"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitXY" />
                <ProgressBar
                    android:id="@+id/mediaLoader"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"/>

                <ImageView
                    android:id="@+id/btnImageOverflow"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="6dp"
                    android:padding="5dp"
                    android:background="@drawable/bg_rounded_circle"
                    android:src="@drawable/download_minimalistic_svgrepo_com"
                    android:backgroundTint="#DDDDDD" />

                <ImageView
                    android:id="@+id/imgPlayVideo"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_gravity="center"
                    android:visibility="gone"
                    android:src="@drawable/play_circle"
                    android:background="#40000000" />

            </FrameLayout>

        </com.google.android.material.card.MaterialCardView>
        <TextView
            android:id="@+id/txtImageCaption"
            android:layout_width="200dp"
            android:textSize="13sp"
            android:textColor="@color/color_kia_black"
            android:layout_height="wrap_content"
            android:visibility="gone" />
    </LinearLayout>

    <!-- VOICE -->
    <LinearLayout
        android:id="@+id/layoutVoice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:background="@drawable/vc_bg_chat_bubble_incoming"
        android:padding="14dp"
        android:descendantFocusability="blocksDescendants"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/imgrecordTablet"
            android:layout_width="@dimen/_15sdp"
            android:layout_height="@dimen/_15sdp"
            android:background="@drawable/bg_small_cornerradius"
            android:padding="@dimen/_3sdp"
            android:src="@drawable/mic__2_" />

        <TextView
            android:id="@+id/txtVoiceDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textSize="14sp"
            android:text="00:12"/>

        <com.masoudss.lib.WaveformSeekBar
            android:id="@+id/waveformView"
            android:layout_width="120dp"
            android:layout_height="40dp"
            android:layout_marginStart="12dp"/>

        <ImageView
            android:id="@+id/btnPlayVoice"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_marginStart="12dp"
            android:src="@drawable/play_circle"/>

    </LinearLayout>

    <TextView
        android:id="@+id/txtTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textSize="13sp" />

</LinearLayout>