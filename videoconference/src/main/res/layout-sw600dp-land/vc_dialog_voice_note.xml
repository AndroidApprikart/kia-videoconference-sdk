<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingBottom="@dimen/_12sdp"
    android:background="@drawable/drawable_dialog_background"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/drawable_dialog_background"
        android:orientation="vertical">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_gravity="center"
        android:gravity="center"
        android:layout_marginTop="@dimen/_10sdp"
        android:paddingHorizontal="@dimen/_20sdp"
        android:paddingVertical="@dimen/_4sdp"
        android:layout_height="wrap_content">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Voice note"
            android:textSize="18sp"
            android:gravity="center_vertical"
            android:fontFamily="@font/kia_signature_fix_bold"
            android:textColor="@color/black"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btnCloseVoice"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:src="@drawable/cancel__1_" />
    </RelativeLayout>


    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:id="@+id/line"
        android:background="@color/grey"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:paddingHorizontal="@dimen/_20sdp"
        android:paddingVertical="@dimen/_5sdp"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Record"
            android:fontFamily="@font/kia_signature_fix_regular"
            android:textColor="@color/black"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:padding="@dimen/_10sdp"
            android:background="@drawable/background_greyborder_filled_cornered"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="@dimen/_25sdp"
                android:layout_height="@dimen/_25sdp"
                android:padding="@dimen/_5sdp"
                android:background="@color/colorPrimary_kia_kandid"
                android:src="@drawable/mic__2_" />

            <!-- WAVEFORM TAKES REMAINING SPACE -->
            <com.masoudss.lib.WaveformSeekBar
                android:id="@+id/waveformView"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="12dp"
                android:layout_weight="1"/>

            <!-- TIMER ALWAYS AT END -->
            <TextView
                android:id="@+id/txtVoiceTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="00:00"
                android:fontFamily="@font/kia_signature_fix_regular"
                android:textColor="@color/black"
                android:textSize="14sp"/>

            <!-- PLAY BUTTON -->
            <ImageView
                android:id="@+id/btnPlayPauseVoice"
                android:layout_width="@dimen/_25sdp"
                android:layout_height="@dimen/_25sdp"
                android:padding="@dimen/_5sdp"
                android:layout_marginStart="12dp"
                android:visibility="gone"
                android:src="@drawable/play_circle"/>

            <!-- DELETE BUTTON -->
            <ImageView
                android:id="@+id/btnDeleteVoice"
                android:layout_width="@dimen/_25sdp"
                android:layout_height="@dimen/_25sdp"
                android:padding="@dimen/_5sdp"
                android:layout_marginStart="8dp"
                android:visibility="gone"
                android:src="@drawable/delete"/>

        </LinearLayout>

    </LinearLayout>


    <LinearLayout
        android:id="@+id/buttonLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/white"
        android:paddingHorizontal="@dimen/_10sdp"
        android:paddingTop="2dp"
        android:paddingBottom="@dimen/_5sdp"
        android:layout_marginTop="@dimen/_15sdp">

        <!-- RECORD BUTTON -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnRecordVoice"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/recording"
            android:textAllCaps="false"
            android:gravity="center"
            android:fontFamily="@font/kia_signature_fix_regular"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:background="@color/colorPrimary_kia_kandid"
            android:layout_marginHorizontal="@dimen/_5sdp"/>

        <!-- ACTION BUTTON GROUP -->
        <LinearLayout
            android:id="@+id/actionButtonsLayout"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/_10sdp"
            android:visibility="visible">

            <!-- PAUSE -->
            <LinearLayout
                android:id="@+id/pauseIcon"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:visibility="gone"
                android:orientation="horizontal"
                android:layout_marginEnd="@dimen/_5sdp"
                android:background="@drawable/bg_main_color_btn">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/pause"
                    android:contentDescription="@null"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pause"
                    android:maxLines="1"
                    android:layout_marginStart="6dp"
                    android:textSize="16sp"
                    android:textColor="@color/color_kia_black"
                    android:fontFamily="@font/kia_signature_fix_bold"/>
            </LinearLayout>

            <!-- RESTART -->
            <LinearLayout
                android:id="@+id/restart"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:visibility="gone"
                android:orientation="horizontal"
                android:layout_marginEnd="@dimen/_5sdp"
                android:background="@drawable/bg_main_color_btn">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:visibility="gone"
                    android:contentDescription="@null"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/restart"
                    android:maxLines="1"
                    android:layout_marginStart="6dp"
                    android:textSize="16sp"
                    android:textColor="@color/color_kia_black"
                    android:fontFamily="@font/kia_signature_fix_bold"/>
            </LinearLayout>

            <!-- SEND -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnSaveVoice"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Send"
                android:visibility="gone"
                android:gravity="center"
                android:textAllCaps="false"
                android:background="@color/colorPrimary_kia_kandid"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:fontFamily="@font/kia_signature_fix_regular"/>
        </LinearLayout>
    </LinearLayout>
    </LinearLayout>
</LinearLayout>
