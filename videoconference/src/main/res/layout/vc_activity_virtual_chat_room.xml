<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:fitsSystemWindows="true"
        android:background="@color/bg_message_screen">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/color_kia_black"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingVertical="@dimen/_8sdp"
        android:orientation="horizontal"
        android:paddingEnd="12dp">

        <!-- Back -->
        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:scaleType="fitCenter"
            android:layout_centerVertical="true"
            android:src="@drawable/arrow_back__1_" />

        <ImageView
            android:layout_centerVertical="true"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:padding="@dimen/_5sdp"
            android:layout_marginStart="@dimen/_5sdp"
            android:background="@drawable/background_whiteborder"
            android:src="@drawable/sms" />


        <!-- Title Container -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="@dimen/_5sdp"
            android:layout_toEndOf="@id/btnBack"
            android:gravity="start"
            android:layout_weight="1"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:id="@+id/repairOrderLayout"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:id="@+id/txtRoomTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RO R202401012 | "
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:layout_gravity="start"
                        android:textStyle="bold" />
                </LinearLayout>


                <TextView
                    android:id="@+id/txtStatusChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/vc_bg_status_chip"
                    android:layout_gravity="start"
                    android:text="Open"
                    android:layout_marginTop="@dimen/_5sdp"
                    android:paddingVertical="@dimen/_2sdp"
                    android:paddingHorizontal="@dimen/_5sdp"
                    android:fontFamily="@font/kia_signature_fix_regular"
                    android:textColor="@color/white"
                    android:textSize="8sp" />

            </LinearLayout>

        </LinearLayout>

        <ImageView
            android:id="@+id/btnVideoCall"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@drawable/videocam" />

    </LinearLayout>


    <!-- Messages list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp" />

    <!-- Typing Indicator -->
    <TextView
        android:id="@+id/txtTypingIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="4dp"
        android:text="Someone is typing..."
        android:textColor="@color/grey_text_color"
        android:textSize="12sp"
        android:visibility="gone" />

    <!-- Quick replies + input unified card -->
        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_marginTop="8dp"
            android:background="@color/grey"/>

        <!-- Bottom unified container -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="0dp"
            android:backgroundTint="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Quick Replies (inside same box) -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="12dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="4dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:padding="@dimen/_5sdp"
                        android:id="@+id/quickReplyContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" />

                </HorizontalScrollView>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="@color/grey"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/_5sdp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:paddingHorizontal="@dimen/_5sdp"
                            android:paddingVertical="@dimen/_5sdp"
                            android:background="@drawable/bg_comment_box"
                            android:backgroundTint="#F7F7F7"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <EditText
                                android:id="@+id/edtMessageTablet"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:fontFamily="@font/kia_signature_fix_regular"
                                android:hint="Text here"
                                android:layout_gravity="center_vertical"
                                android:textSize="14sp"
                                android:background="@null"
                                android:textColor="@color/black"
                                android:inputType="textMultiLine"
                                android:maxLines="4"
                                android:minLines="1"
                                android:scrollbars="vertical"
                                android:gravity="center_vertical"
                                />

                            <ImageView
                                android:id="@+id/imgAttachmentTablet"
                                android:layout_width="@dimen/_20sdp"
                                android:layout_height="@dimen/_20sdp"
                                android:layout_marginStart="8dp"
                                android:visibility="visible"
                                android:layout_gravity="center"
                                android:src="@drawable/screen_share"
                                />

                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:id="@+id/recordLayout"
                            android:layout_marginStart="8dp"
                            android:gravity="center"
                            >

                            <ImageView
                                android:background="@drawable/bg_small_cornerradius"
                                android:id="@+id/imgrecordTablet"
                                android:layout_width="@dimen/_25sdp"
                                android:layout_height="@dimen/_25sdp"
                                android:padding="@dimen/_3sdp"
                                android:layout_gravity="center"
                                android:src="@drawable/mic__2_"
                                />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="40dp"
                            android:id="@+id/sendLayout"
                            android:layout_height="40dp"
                            android:layout_marginStart="8dp"
                            android:visibility="gone"
                            android:gravity="center"
                            >

                            <ImageView
                                android:background="@drawable/bg_small_cornerradius"
                                android:id="@+id/imgSendTablet"
                                android:layout_width="@dimen/_25sdp"
                                android:layout_height="@dimen/_25sdp"
                                android:padding="@dimen/_3sdp"
                                android:layout_gravity="center"
                                android:src="@drawable/send"
                                />

                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    </LinearLayout>

</layout>