<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <variable
            name="soundDeviceVM"
            type="com.app.vc.soundDevice.SoundDeviceViewModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bottom_sheet"
        android:minHeight="10dp"
        android:orientation="vertical"
        android:padding="@dimen/_10sdp"

      >

        <View
            android:id="@+id/line_divider_for_sound_device"
            android:layout_width="@dimen/_30sdp"
            android:layout_height="@dimen/_2sdp"
            android:layout_marginVertical="@dimen/_10sdp"
            android:background="@color/color_kia_black"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />


        <TextView
            android:id="@+id/tv_sound_header"
            android:fontFamily="@font/kia_signature_fix_bold"
            android:layout_marginStart="@dimen/_10sdp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:layout_marginTop="@dimen/_10sdp"
            android:text="@string/sound_device"
            android:textSize="14sp"
            android:textAlignment="viewStart"
            android:textColor="@color/black"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/line_divider_for_sound_device" />


        <androidx.appcompat.widget.LinearLayoutCompat
            android:id="@+id/device_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_5sdp"
            android:orientation="vertical"
            app:layout_constraintStart_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_sound_header">

            <RelativeLayout
                android:id="@+id/speaker_phone_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/_10sdp"
                android:visibility="visible">

                <ImageView
                    android:id="@+id/speaker_phone_iv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="@dimen/_5sdp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_audio_output_devices" />

                <TextView
                    style="@style/text_view_regular"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginHorizontal="@dimen/_5sdp"
                    android:textAllCaps="false"
                    android:layout_toEndOf="@id/speaker_phone_iv"
                    android:text="Speaker Phone"
                    android:textSize="12sp"
                    android:textColor="@color/color_kia_black"
                    android:textAlignment="viewStart" />

                <ImageView
                    android:id="@+id/speaker_phone_selected_option"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_selected"
                    android:visibility="gone" />


            </RelativeLayout>

            <RelativeLayout
                android:id="@+id/earpiece_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/speaker_phone_layout"
                android:paddingHorizontal="@dimen/_10sdp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/earpiece_iv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="@dimen/_5sdp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_audio_output_devices" />

                <TextView
                    style="@style/text_view_regular"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginHorizontal="@dimen/_5sdp"
                    android:fontFamily="@font/kia_signature_fix_regular"
                    android:layout_toEndOf="@id/earpiece_iv"
                    android:textColor="@color/color_kia_black"
                    android:text="EARPIECE"
                    android:textSize="12sp"
                    android:textAlignment="viewStart" />

                <ImageView
                    android:id="@+id/earpiece_selected_option"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_selected"
                    android:visibility="gone" />


            </RelativeLayout>

            <RelativeLayout
                android:id="@+id/wired_headset_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/earpiece_layout"
                android:paddingHorizontal="@dimen/_10sdp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/wired_headset_iv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="@dimen/_5sdp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_headset" />

                <TextView
                    style="@style/text_view_regular"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginHorizontal="@dimen/_5sdp"
                    android:fontFamily="@font/kia_signature_fix_regular"
                    android:layout_toEndOf="@id/wired_headset_iv"
                    android:textColor="@color/color_kia_black"
                    android:text="Wired Headset"
                    android:textSize="12sp"
                    android:textAlignment="viewStart" />

                <ImageView
                    android:id="@+id/wired_headset_selected_option"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_selected"
                    android:visibility="gone" />


            </RelativeLayout>

            <RelativeLayout
                android:id="@+id/bluetooth_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/wired_headset_layout"
                android:paddingHorizontal="@dimen/_10sdp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/bluetooth_iv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_bluetooth" />

                <TextView
                    style="@style/text_view_regular"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginHorizontal="@dimen/_10sdp"
                    android:layout_toEndOf="@id/bluetooth_iv"
                    android:fontFamily="@font/kia_signature_fix_regular"
                    android:textColor="@color/color_kia_black"
                    android:text="Bluetooth"
                    android:textSize="12sp"
                    android:textAlignment="viewStart" />

                <ImageView
                    android:id="@+id/bluetooth_selected_option"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_selected"
                    android:visibility="gone" />


            </RelativeLayout>

        </androidx.appcompat.widget.LinearLayoutCompat>


        <RelativeLayout
            android:id="@+id/cancel_sound_device_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/device_layout"
            android:paddingHorizontal="@dimen/_10sdp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/device_layout">

            <ImageView
                android:id="@+id/img_cancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="@dimen/_5sdp"
                android:src="@drawable/ic_bluetooth"
                android:scaleType="fitCenter"
                app:tint="@color/white"/>

            <TextView
                android:id="@+id/tv_cancel_sound_device"
                style="@style/text_view_regular"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginLeft="@dimen/_5sdp"
                android:textColor="@color/color_kia_black"
                android:layout_toEndOf="@id/img_cancel"
                android:text="@string/cancel"
                android:textSize="12sp"
                android:textAlignment="viewStart" />


        </RelativeLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>