<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/_10sdp"
        android:layout_marginEnd="@dimen/_5sdp"
        android:layout_marginVertical="@dimen/_5sdp"
        android:padding="@dimen/_3sdp"
        android:background="@drawable/bg_local_message">

        <TextView
            android:id="@+id/user_name_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/kia_signature_fix_bold"
            android:text="Vinant"
            android:textColor="@color/color_kia_black"
            android:textSize="14sp" />

        <RelativeLayout
            android:id="@+id/self_layout_estimation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:background="@color/white"
            android:visibility="visible"
            android:layout_below="@id/user_name_tv"
            tools:ignore="RelativeOverlap">

            <TextView
                android:id="@+id/sender_user_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="@dimen/message_user_name_ts" />
            <!--                Self Layout Estimation Header-->
            <LinearLayout
                android:id="@+id/ll_self_table_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:backgroundTint="@color/white"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_weight="0.3"
                    android:fontFamily="@font/kia_signature_fix_bold"
                    android:gravity="center_horizontal"
                    android:textColor="@color/color_kia_black"
                    android:paddingHorizontal="5dp"
                    android:paddingVertical="10dp"
                    android:text="Name" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.3"
                    android:fontFamily="@font/kia_signature_fix_bold"
                    android:gravity="center_horizontal"
                    android:textColor="@color/color_kia_black"
                    android:paddingHorizontal="5dp"
                    android:paddingVertical="10dp"
                    android:text="Quantity"

                    />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.3"
                    android:fontFamily="@font/kia_signature_fix_bold"
                    android:gravity="center_horizontal"
                    android:paddingHorizontal="5dp"
                    android:paddingVertical="10dp"
                    android:textColor="@color/color_kia_black"
                    android:text="Price" />

                <TextView
                    android:id="@+id/tv_checkbox_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.1"
                    android:fontFamily="@font/kia_signature_fix_bold"
                    android:gravity="center"
                    android:padding="10dp" />
            </LinearLayout>

            <!--                Self Layout Estimation Part List Header-->
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tv_estimation_part_list_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/kia_signature_fix_regular"
                android:textColor="@color/color_kia_black"
                android:paddingVertical="10dp"
                android:text="@string/header_part_list"
                android:layout_below="@id/ll_self_table_header"
                android:paddingHorizontal="5dp" />

            <!--                Self Layout Estimation Part List-->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_estimation_part_list"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@+id/tv_estimation_part_list_header"
                android:background="@color/white"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:itemCount="1"
                tools:listitem="@layout/message_estimation_list_item" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tv_estimation_labour_list_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/kia_signature_fix_regular"
                android:textColor="@color/color_kia_black"
                android:paddingVertical="10dp"
                android:text="@string/header_labour_list"
                android:layout_below="@id/rv_estimation_part_list"
                android:paddingHorizontal="5dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_estimation_labour_list"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@+id/tv_estimation_labour_list_header"
                android:background="@color/white"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:itemCount="1"
                tools:listitem="@layout/message_estimation_list_item" />

            <RelativeLayout
                android:id="@+id/rv_approval_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@+id/rv_estimation_labour_list"
                android:layout_centerHorizontal="true"
                android:gravity="center">

                <TextView
                    android:id="@+id/tv_estimate_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:fontFamily="@font/kia_signature_fix_bold"
                    android:foregroundGravity="center"
                    android:text="Approved"
                    android:textColor="@color/green"
                    android:textSize="16sp" />

            </RelativeLayout>

        </RelativeLayout>

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tv_local_msg_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/_5sdp"
            android:layout_marginBottom="@dimen/_5sdp"
            android:text="status"
            android:textSize="10sp"
            android:visibility="visible"
            android:layout_marginTop="@dimen/_5sdp"
            android:layout_below="@id/self_layout_estimation"
            android:layout_toStartOf="@id/tv_time_stamp_self"
            app:fontFamily="@font/kia_signature_fix_regular" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tv_time_stamp_self"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10:20"
            android:textSize="10sp"
            android:layout_marginTop="@dimen/_5sdp"
            android:layout_below="@id/self_layout_estimation"
            app:fontFamily="@font/kia_signature_fix_regular"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="@dimen/_5sdp"/>


    </RelativeLayout>
</layout>