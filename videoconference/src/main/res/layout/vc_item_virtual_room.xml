<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="#C9CBCF"
    card_view:cardUseCompatPadding="true"
    card_view:cardElevation="0dp">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">


        <ImageView
            android:layout_centerVertical="true"
            android:layout_width="@dimen/_35sdp"
            android:id="@+id/iconChat"
            android:layout_height="@dimen/_35sdp"
android:layout_marginTop="@dimen/_5sdp"
            android:padding="@dimen/_10sdp"
            android:layout_marginStart="@dimen/_5sdp"
            android:background="@drawable/bg_msg_icon"
            android:src="@drawable/sms__1_" />



        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"

                    android:text=""
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:fontFamily="@font/kia_signature_fix_bold"
                    android:textColor="@color/color_kia_black"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="|"
                    android:maxLines="1"
                    android:layout_marginStart="@dimen/_5sdp"
                    android:ellipsize="end"
                    android:fontFamily="@font/kia_signature_fix_bold"
                    android:textColor="@color/color_kia_black"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/roDate"
                    android:layout_marginStart="@dimen/_5sdp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:ellipsize="end"
                    android:fontFamily="@font/kia_signature_fix_bold"
                    android:textColor="@color/color_kia_black"
                    android:textSize="15sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_5sdp"
                android:orientation="horizontal"
                android:gravity="center_vertical">


                <ImageView

                    android:layout_width="25dp"
                    android:id="@+id/locIcon"
                    android:layout_height="25dp"
                    android:layout_gravity="center"
                    android:src="@drawable/group_13607__1_" />

                <TextView
                    android:id="@+id/dealershipName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="ASB  Automobiles"
                    android:maxLines="1"
                    android:fontFamily="@font/kia_signature_fix_light"
                    android:ellipsize="end"
                    android:textColor="@color/color_kia_black"
                    android:textSize="14sp"
                    android:textStyle="bold" />


            </LinearLayout>




            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_5sdp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/txtStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/vc_bg_status_chip"
                    android:paddingHorizontal="@dimen/_5sdp"
                    android:paddingTop="2dp"
                    android:textAllCaps="false"
                    android:fontFamily="@font/kia_signature_fix_regular"

                    android:paddingBottom="2dp"
                    android:text="open"
                    android:textColor="@color/white"
                    android:textSize="12sp" />

<!--                <TextView-->
<!--                    android:id="@+id/txtSubtitle"-->
<!--                    android:layout_width="wrap_content"-->
<!--                    android:layout_height="wrap_content"-->
<!--                    android:layout_marginStart="8dp"-->
<!--                    android:maxLines="1"-->
<!--                    android:ellipsize="end"-->
<!--                    android:fontFamily="@font/kia_signature_fix_regular"-->
<!--                    android:text="Thu \u2022 11:32am"-->
<!--                    android:textColor="@color/self_time_color"-->
<!--                    android:textSize="12sp" />-->
            </LinearLayout>



        </LinearLayout>
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_5sdp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtUnreadBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="24dp"
                android:layout_gravity="center"
                android:gravity="center"
                android:layout_marginEnd="8dp"
                android:background="@drawable/vc_bg_unread_badge"

                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:text="2"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:visibility="gone" />


        </LinearLayout>


    </LinearLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/_5sdp"
            android:visibility="visible"
            android:orientation="horizontal"
            android:background="#E6E7E9"
            android:id="@+id/appointmentstatusLayout">


            <TextView
                android:id="@+id/appointmentconfirmed"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Appointment confirmed for 2 April , 2026"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_gravity="center"
                android:gravity="center"
                android:fontFamily="@font/kia_signature_fix_bold"
                android:textColor="@color/color_kia_black"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>



    </LinearLayout>




</androidx.cardview.widget.CardView>

