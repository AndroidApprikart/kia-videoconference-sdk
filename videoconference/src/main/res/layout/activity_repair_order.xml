<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        android:fitsSystemWindows="true">

        <!-- Repair Order Header -->
        <LinearLayout
            android:id="@+id/repairOrderLayout1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#05141F"
            android:orientation="vertical"
            android:padding="@dimen/_10sdp"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Back Row -->
            <LinearLayout
                android:id="@+id/backLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="@dimen/_10sdp">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/btnBack"
                    android:layout_width="@dimen/_25sdp"
                    android:layout_height="@dimen/_25sdp"
                    android:src="@drawable/arrow_back" />

                <TextView
                    android:id="@+id/repairordertv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="REPAIR ORDER"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:fontFamily="@font/kia_signature_fix_bold" />

            </LinearLayout>

            <!-- Card -->
            <LinearLayout
                android:id="@+id/repairLayout2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_10sdp"
                android:background="@drawable/background_cornerradius_medium"
                android:orientation="vertical"
                android:padding="@dimen/_10sdp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/orderId"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RO R202401012"
                        android:textColor="@color/grey_text_color"
                        android:textSize="12sp"
                        android:fontFamily="@font/kia_signature_fix_bold" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1"/>

                    <TextView
                        android:id="@+id/status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Open"
                        android:textColor="@color/white"
                        android:background="@drawable/background_status"
                        android:paddingHorizontal="@dimen/_10sdp"
                        android:paddingVertical="@dimen/_6sdp"
                        android:textSize="12sp"
                        android:fontFamily="@font/kia_signature_fix_regular" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_10sdp"
                    android:background="@drawable/dotted_line"/>

                <TextView
                    android:id="@+id/repairDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Customer reports a loud grinding noise..."
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:fontFamily="@font/kia_signature_fix_light"/>
                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/kia_signature_fix_bold"
                    android:textStyle="bold"
                    android:id="@+id/createdDayTv"
                    android:textSize="12sp"
                    android:layout_marginStart="@dimen/_4sdp"
                    android:text="Thu"
                    android:textColor="@color/black"/>
                <View android:layout_width="@dimen/_3sdp" android:layout_height="@dimen/_3sdp" android:layout_gravity="center" android:layout_marginStart="@dimen/_5sdp" android:background="@drawable/single_dot"/> <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/kia_signature_fix_bold" android:textStyle="bold" android:id="@+id/timeTv" android:textSize="12sp" android:layout_marginStart="@dimen/_4sdp" android:text="11:32am" android:textColor="@color/black"/>
            </LinearLayout>

        </LinearLayout>


        <!-- Tabs -->
        <LinearLayout
            android:id="@+id/tabSwitcher"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingHorizontal="8dp"
            android:paddingVertical="10dp"
            android:weightSum="2"
            app:layout_constraintTop_toBottomOf="@id/repairOrderLayout1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tabParticipants"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Participants"
                android:textColor="@color/black"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="@font/kia_signature_fix_bold"/>

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tabMedia"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Media"
                android:textColor="#343434"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="@font/kia_signature_fix_regular"/>

        </LinearLayout>


        <!-- Divider -->
        <View
            android:id="@+id/line"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@color/grey"
            app:layout_constraintTop_toBottomOf="@id/tabSwitcher"/>


        <!-- Tab Indicator -->
        <View
            android:id="@+id/tabIndicator"
            android:layout_width="0dp"
            android:layout_height="4dp"
            android:background="@color/colorPrimary_kia_kandid"
            app:layout_constraintTop_toBottomOf="@id/tabSwitcher"
            app:layout_constraintStart_toStartOf="parent"/>


        <!-- Network Banner -->
        <include
            android:id="@+id/includeNetworkErrorBanner"
            layout="@layout/vc_layout_network_error_banner"
            app:layout_constraintTop_toBottomOf="@id/line"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>


        <!-- Fragment Container -->
        <FrameLayout
            android:id="@+id/FragmentContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/tabIndicator"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>