<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">
    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:fitsSystemWindows="true"
        android:background="@color/white"
        android:layout_height="match_parent"
        >

        <LinearLayout
            android:id="@+id/repairOrderLayout1"
            android:layout_width="match_parent"
            android:gravity="center"
            android:padding="@dimen/_10sdp"
            android:background="#05141F"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="@dimen/_5sdp"
                android:id="@+id/backLayout"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/_10sdp"
                app:layout_constraintTop_toTopOf="parent"
                android:orientation="horizontal">


                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/btnBack"
                    android:layout_width="@dimen/_25sdp"
                    android:layout_height="@dimen/_25sdp"
                    android:layout_gravity="center|center_horizontal"
                    android:src="@drawable/arrow_back" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/repairordertv"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:text="REPAIR ORDER"
                    android:paddingLeft="-25dp"
                    android:textColor="@color/white"
                    android:fontFamily="@font/kia_signature_fix_bold"
                    android:textSize="14sp"/>

            </LinearLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="@dimen/_10sdp"
                android:padding="@dimen/_10sdp"
                android:background="@drawable/background_cornerradius_medium"
                android:id="@+id/repairLayout2">

               <LinearLayout
                   android:layout_width="match_parent"
                   android:layout_height="wrap_content"
                   android:orientation="horizontal">

                   <TextView
                       android:layout_width="wrap_content"
                       android:layout_height="wrap_content"
                       android:id="@+id/orderId"
                       android:layout_gravity="center"
                       android:gravity="center"
                       android:letterSpacing="0.1"
                       android:text="RO R202401012"
                       android:textColor="@color/grey_text_color"
                       android:fontFamily="@font/kia_signature_fix_bold"
                       android:textSize="12sp"/>

                   <View
                       android:layout_width="0dp"
                       android:layout_height="0dp"
                       android:layout_weight="1"/>

                   <TextView
                       android:layout_width="wrap_content"
                       android:layout_height="wrap_content"
                       android:layout_gravity="center|center_horizontal"
                       android:text="Open"
                       android:paddingHorizontal="@dimen/_10sdp"
                       android:paddingVertical="@dimen/_6sdp"
                       android:textSize="12sp"
                       android:textColor="@color/white"
                       android:fontFamily="@font/kia_signature_fix_regular"
                       android:background="@drawable/background_status"
                       android:id="@+id/status"

                       />












               </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_10sdp"
                    android:layout_marginTop="@dimen/_3sdp"
                    android:background="@drawable/dotted_line"/>


                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/kia_signature_fix_light"
                    android:id="@+id/repairDescription"
                    android:textSize="14sp"
                    android:text="Customer reports a loud grinding noise from the engine bay when accelerating along with a Check Engine light that has been flashing repeatedly."
                    android:textColor="@color/black"/>



                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/repairlayout3"
                    android:layout_marginTop="@dimen/_5sdp"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/kia_signature_fix_light"
                        android:id="@+id/roomCreatedTv"
                        android:textSize="12sp"
                        android:text="Room created on"
                        android:textColor="#05141F"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/kia_signature_fix_bold"
                        android:textStyle="bold"
                        android:id="@+id/createdDayTv"
                        android:textSize="12sp"
                        android:layout_marginStart="@dimen/_4sdp"
                        android:text="Thu"
                        android:textColor="@color/black"/>
                    <View
                        android:layout_width="@dimen/_3sdp"
                        android:layout_height="@dimen/_3sdp"
                        android:layout_gravity="center"
                        android:layout_marginStart="@dimen/_5sdp"
                        android:background="@drawable/single_dot"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/kia_signature_fix_bold"
                        android:textStyle="bold"
                        android:id="@+id/timeTv"
                        android:textSize="12sp"
                        android:layout_marginStart="@dimen/_4sdp"
                        android:text="11:32am"
                        android:textColor="@color/black"/>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@+id/repairOrderLayout1"
            android:padding="@dimen/_10sdp"
            app:layout_constraintStart_toStartOf="parent"
            android:id="@+id/tabSwitcher"
            android:gravity="center"
            android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tabParticipants"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:paddingHorizontal="@dimen/_15sdp"
                    android:text="@string/participants"
                    android:fontFamily="@font/kia_signature_fix_bold"
                    android:textSize="14sp"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tabMedia"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:paddingHorizontal="@dimen/_15sdp"
                    android:text="Media"
                    android:fontFamily="@font/kia_signature_fix_regular"
                    android:textSize="14sp"
                    android:textColor="#343434"
                    android:textStyle="bold"
                    />



        </LinearLayout>


        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:id="@+id/line"
            app:layout_constraintTop_toBottomOf="@+id/tabSwitcher"
            android:background="@color/grey"/>

        <View
            android:id="@+id/tabIndicator"
            android:layout_width="0dp"
            android:layout_height="4dp"
            android:background="@color/colorPrimary_kia_kandid"
            app:layout_constraintBottom_toBottomOf="@id/line"
            app:layout_constraintStart_toStartOf="parent"/>
        <FrameLayout
            android:id="@+id/FragmentContainer"
            android:layout_width="match_parent"
            app:layout_constraintTop_toBottomOf="@+id/line"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_height="0dp" />



    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
