<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="start"
    android:orientation="vertical"
    android:padding="8dp"
    >

    <LinearLayout
        android:id="@+id/layoutText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/vc_bg_chat_bubble_incoming"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtSenderInitial"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/bg_rounded_circle"
                android:gravity="center"
                android:text="U"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtSenderName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="User"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:textSize="12sp"
                 />

            <TextView
                android:id="@+id/txtSenderRole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:background="@drawable/vc_bg_status_chip"
                android:text="SA"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome, your appointment is booked."
            android:textColor="@color/color_kia_black"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/txtFileName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:textColor="@color/color_kia_black"
            android:textSize="13sp" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/layoutFileContainer"
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:background="@drawable/vc_bg_chat_bubble_incoming"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/layoutFileSenderRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="12dp"
                android:layout_marginBottom="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtFileSenderInitial"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_rounded_circle"
                    android:gravity="center"
                    android:text="U"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtFileSenderName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="User"
                    android:textColor="@color/black"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtFileSenderRole"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:background="@drawable/vc_bg_status_chip"
                    android:text="SA"
                    android:textColor="@color/white"
                    android:textSize="10sp"
                    android:visibility="gone" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end"
                android:paddingTop="4dp"
                android:paddingEnd="4dp">
                <ImageView
                    android:id="@+id/btnFileOverflow"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="6dp"
                    android:padding="5dp"
                    android:background="@drawable/bg_rounded_circle"
                    android:src="@drawable/download_minimalistic_svgrepo_com"
                    android:backgroundTint="#DDDDDD" />
            </LinearLayout>
            <ImageView
                android:id="@+id/imgFileThumbnail"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:visibility="gone"
                android:scaleType="centerCrop"
                android:contentDescription="@null" />

            <LinearLayout
                android:layout_width="180dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:minWidth="180dp">

            <ImageView
                android:id="@+id/imgFileIcon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/file_pdf_icon"
                android:contentDescription="@null"
                android:padding="8dp" />
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/txtFileTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="middle"
                    android:maxLines="2"
                    android:textColor="@color/color_kia_black"
                    android:textSize="13sp" />
                <TextView
                    android:id="@+id/txtFileSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="PDF"
                    android:textColor="@color/grey_text_color"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>
            <TextView
                android:id="@+id/txtFileCaption"
                android:layout_width="180dp"
                android:layout_height="wrap_content"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="4dp"
                android:paddingBottom="8dp"
                android:gravity="start"
                android:visibility="gone"
                android:maxLines="4"
                android:textColor="@color/color_kia_black"
                android:textSize="12sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/layoutImageContainer"
        android:layout_width="180dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/vc_bg_chat_bubble_incoming"
        android:padding="@dimen/_8sdp"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/layoutMediaSenderRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtMediaSenderInitial"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/bg_rounded_circle"
                android:gravity="center"
                android:text="U"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtMediaSenderName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="User"
                android:textColor="@color/black"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtMediaSenderRole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:background="@drawable/vc_bg_status_chip"
                android:text="SA"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtImageCaption"
            android:layout_width="160dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:gravity="start"
            android:visibility="gone"
            android:maxLines="4"
            android:textColor="@color/color_kia_black"
            android:textSize="12sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_gravity="center"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/imgAttachment"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitXY" />
                <ProgressBar
                    android:id="@+id/mediaLoader"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"/>

                <ImageView
                    android:id="@+id/btnImageOverflow"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="6dp"
                    android:padding="5dp"
                    android:background="@drawable/bg_rounded_circle"
                    android:src="@drawable/download_minimalistic_svgrepo_com"
                    android:backgroundTint="#DDDDDD" />

                <ImageView
                    android:id="@+id/imgPlayVideo"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_gravity="center"
                    android:visibility="gone"
                    android:src="@drawable/play_circle"
                    android:background="#40000000" />

            </FrameLayout>

        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutVoice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:background="@drawable/vc_bg_chat_bubble_incoming"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_btn_speak_now"
            android:contentDescription="@null" />
        <TextView
            android:id="@+id/txtVoiceDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="00:12"
            android:textColor="@color/color_kia_black"
            android:textSize="13sp" />
        <com.app.vc.views.WaveformView
            android:id="@+id/voiceWaveformView"
            android:layout_width="80dp"
            android:layout_height="24dp"
            android:layout_marginStart="8dp" />
        <ImageView
            android:id="@+id/btnPlayVoice"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="8dp"
            android:src="@android:drawable/ic_media_play"
            android:contentDescription="@null" />
    </LinearLayout>

    <TextView
        android:id="@+id/txtTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="10:30am"
        android:textColor="@color/self_time_color"
        android:textSize="11sp" />

</LinearLayout>
