<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="messageVM"
            type="com.app.vc.message.MessageViewModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_bottom_sheet"
        android:minHeight="10dp"
        android:theme="@style/Base.Theme.VideoConference"
        android:orientation="vertical">


        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/app_bar_layout"
            android:layout_width="match_parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_height="wrap_content"
            android:background="@color/color_kia_black"
            android:theme="@style/Theme.AppCompat.Light">
            <androidx.appcompat.widget.Toolbar
                android:id="@+id/message_tool_bar"
                android:layout_width="match_parent"
                android:layout_height="?android:attr/actionBarSize"
                android:fitsSystemWindows="true"
                android:gravity="start"
                app:contentInsetStartWithNavigation="0dp"
                app:layout_collapseMode="pin"
                app:navigationIcon="@drawable/ic_close">


                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/messages"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center|center_horizontal"
                    android:text="Messages"
                    style="@style/text_view_regular"
                    android:textSize="@dimen/_14ssp"
                    android:textColor="@color/white" />

            </androidx.appcompat.widget.Toolbar>


        </com.google.android.material.appbar.AppBarLayout>


        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_data"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginVertical="@dimen/_10sdp"
            android:padding="@dimen/_5ssp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toTopOf="@id/rl_message_layout"
            app:layout_constraintTop_toBottomOf="@id/app_bar_layout" />


        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/rl_message_layout"
            android:layout_alignParentBottom="true"
            android:layout_width="match_parent"
            android:padding="@dimen/_5sdp"
            android:elevation="@dimen/_5sdp"
            android:background="@drawable/bg_dialog"
            android:backgroundTint="#C1BEBE"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_height="?android:attr/actionBarSize">

            <androidx.appcompat.widget.AppCompatEditText
                android:id="@+id/ed_useR_input"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:background="@drawable/bg_send_msg"
                style="@style/text_view_regular"
                android:ellipsize="end"
                app:layout_constraintEnd_toStartOf="@id/btn_attach_file"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_centerVertical="true"
                android:hint="Type your message"
                android:imeOptions="actionDone|flagNoFullscreen"
                android:text="@={messageVM.userMessageInput}"
                tools:ignore="Autofill,RtlSymmetry"
                android:layout_marginEnd="@dimen/_5sdp"
                android:paddingHorizontal="10dp"/>

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/btn_attach_file"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:layout_marginHorizontal="@dimen/_3sdp"
                android:background="@drawable/bg_message_action"
                android:backgroundTint="@color/color_kia_black"
                android:tint="@color/white"
                android:scaleType="centerInside"
                app:layout_constraintEnd_toStartOf="@id/btn_send_message"
                app:layout_constraintBottom_toBottomOf="parent"
                android:src="@drawable/ic_attach_file" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/btn_send_message"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:gravity="center"
                android:background="@drawable/bg_message_action"
                android:backgroundTint="@color/color_kia_black"
                android:tint="@color/white"
                android:src="@drawable/ic_send_message" />
        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>