<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/_16sdp">

        <TextView
            android:id="@+id/tvManageTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Manage"
            android:textSize="16sp"
            android:textColor="@color/black"
            android:fontFamily="@font/kia_signature_fix_bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_4sdp"
            android:text="Participants"
            android:textSize="14sp"
            android:textColor="@color/black" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_12sdp"
            android:orientation="vertical">

            <!-- Vijaykumar (You) -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Vijaykumar  •  You"
                android:textSize="14sp"
                android:textColor="@color/black"
                android:paddingVertical="@dimen/_4sdp" />

            <!-- Lata (Customer) -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Lata  •  Customer"
                android:textSize="14sp"
                android:textColor="@color/black"
                android:paddingVertical="@dimen/_4sdp" />

            <!-- Ajay (Service Advisor) with Change button -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:paddingVertical="@dimen/_4sdp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Ajay  •  Service Advisor"
                    android:textSize="14sp"
                    android:textColor="@color/black" />

                <Button
                    android:id="@+id/btnChangeAdvisor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Change"
                    android:textAllCaps="false" />
            </LinearLayout>

            <!-- Bhagat (Service Manager) -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bhagat  •  Service Manager"
                android:textSize="14sp"
                android:textColor="@color/black"
                android:paddingVertical="@dimen/_4sdp" />
        </LinearLayout>

    </LinearLayout>
</layout>

