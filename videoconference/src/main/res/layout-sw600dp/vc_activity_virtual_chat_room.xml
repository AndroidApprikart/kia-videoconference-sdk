<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/bg_message_screen">



    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="@dimen/_5sdp"
        android:id="@+id/backLayout"
        android:layout_gravity="center"
        android:background="#F9F9F9"
        app:layout_constraintTop_toTopOf="parent"
        android:orientation="horizontal">


        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/btnBack"
            android:padding="@dimen/_5sdp"
            android:layout_width="@dimen/_25sdp"
            android:layout_height="@dimen/_25sdp"
            android:layout_gravity="center|center_horizontal"
            android:src="@drawable/keyboard_arrow_down__1_" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/repairordertv"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="Back to Home"
            android:textColor="@color/black"
            android:fontFamily="@font/kia_signature_fix_bold"
            android:textSize="18sp"/>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <androidx.appcompat.widget.AppCompatImageView
            android:layout_width="@dimen/_35sdp"
            android:layout_height="@dimen/_15sdp"
            android:layout_marginEnd="@dimen/_25sdp"
            android:layout_gravity="center|center_horizontal"
            android:src="@drawable/layer1" />




    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:id="@+id/line"
        app:layout_constraintTop_toBottomOf="@+id/tabSwitcher"
        android:background="@color/grey"/>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">




    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="1dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- Left panel -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/white"
            android:orientation="vertical"
            >

            <TextView
                android:id="@+id/txtLeftCustomerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lata"
                android:textColor="@color/color_kia_black"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtLeftRoNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="RO R02401012"
                android:textColor="@color/self_time_color"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/txtLeftStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/vc_bg_status_chip"
                android:paddingLeft="8dp"
                android:paddingTop="2dp"
                android:paddingRight="8dp"
                android:paddingBottom="2dp"
                android:text="OPEN"
                android:textColor="@color/white"
                android:textSize="12sp" />

            <!-- Tabs -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@+id/repairOrderLayout1"
                app:layout_constraintStart_toStartOf="parent"
                android:id="@+id/tabSwitcher"
                android:gravity="center"
                android:layout_marginTop="@dimen/_4sdp"
                android:orientation="horizontal">


                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tabRoDetails"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/roDetails"
                    android:layout_marginStart="@dimen/_5sdp"
                    android:fontFamily="@font/kia_signature_fix_bold"
                    android:textSize="14sp"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tabParticipants"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/participants"
                    android:layout_marginStart="@dimen/_5sdp"
                    android:fontFamily="@font/kia_signature_fix_bold"
                    android:textSize="14sp"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    />



                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tabMedia"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Media"
                    android:layout_marginStart="@dimen/_5sdp"
                    android:fontFamily="@font/kia_signature_fix_regular"
                    android:textSize="14sp"
                    android:textColor="#343434"
                    android:textStyle="bold"
                    />



            </LinearLayout>


            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:id="@+id/line1"
                android:background="@color/grey"/>

            <View
                android:id="@+id/tabIndicator"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:background="@color/colorPrimary_kia_kandid"
 />
            <FrameLayout
                android:id="@+id/FragmentContainer"
                android:layout_width="match_parent"
                android:layout_marginTop="@dimen/_2sdp"
                android:layout_weight="1"
                app:layout_constraintTop_toBottomOf="@+id/line"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_height="0dp" />

            <!-- Simple RO details on left -->

        </LinearLayout>

        <!-- Right panel -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="16dp"
            android:layout_weight="2"
            android:orientation="vertical">

            <!-- Welcome card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtWelcomeHeaderTablet"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Welcome"
                        android:textColor="@color/color_kia_black"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtWelcomeBodyTablet"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Welcome, Lata! Your appointment has been booked under Repair Order (RO) R02401012."
                        android:textColor="@color/color_kia_black"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Messages list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerMessages"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="16dp"
                android:layout_weight="1" />
            <!-- Bottom unified container -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:backgroundTint="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Quick Replies (inside same box) -->
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingStart="12dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="4dp"
                        android:scrollbars="none">

                        <LinearLayout
                            android:id="@+id/quickReplyContainerTablet"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal" />
                    </HorizontalScrollView>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/light_gray_bg" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:padding="8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/edtMessageTablet"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="Text here"
                            android:textSize="15sp"
                            android:textColor="@color/black"
                            android:gravity="center_vertical"
                            />

                        <ImageView
                            android:id="@+id/imgAttachmentTablet"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginStart="8dp"
                            android:src="@drawable/ic_attach"
                            app:tint="@color/light_gray_bg" />

                        <LinearLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:id="@+id/recordLayout"
                            android:layout_marginStart="8dp"
                            android:gravity="center"
                          >

                            <ImageView
                                android:id="@+id/imgrecordTablet"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@drawable/bg_record_button"
                               />
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="40dp"
                            android:id="@+id/sendLayout"
                            android:layout_height="40dp"
                            android:layout_marginStart="8dp"
                            android:visibility="gone"

                            android:gravity="center"
                            >

                            <ImageView
                                android:id="@+id/imgSendTablet"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@drawable/bg_send_button"
                                />
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </LinearLayout>
    </LinearLayout>
    </LinearLayout>

</layout>
