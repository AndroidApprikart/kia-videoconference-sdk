<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/bg_message_screen"
    android:padding="24dp">

    <TextView
        android:id="@+id/txtBreadcrumb"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Home > Chat room"
        android:textColor="@color/color_kia_black"
        android:textSize="13sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- Left panel -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/white"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/txtLeftCustomerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lata"
                android:textColor="@color/color_kia_black"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtLeftRoNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="RO R02401012"
                android:textColor="@color/self_time_color"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/txtLeftStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/vc_bg_status_chip"
                android:paddingLeft="8dp"
                android:paddingTop="2dp"
                android:paddingRight="8dp"
                android:paddingBottom="2dp"
                android:text="OPEN"
                android:textColor="@color/white"
                android:textSize="12sp" />

            <!-- Tabs -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RO Details"
                    android:textColor="@color/color_kia_black"
                    android:textStyle="bold"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Participants"
                    android:textColor="@color/self_time_color"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Media"
                    android:textColor="@color/self_time_color"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Simple RO details on left -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Status:"
                    android:textColor="@color/self_name_color"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/txtLeftRoStatusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Car is in the inspection stage"
                    android:textColor="@color/color_kia_black"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Right panel -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="16dp"
            android:layout_weight="2"
            android:orientation="vertical">

            <!-- Welcome card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtWelcomeHeaderTablet"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Welcome"
                        android:textColor="@color/color_kia_black"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtWelcomeBodyTablet"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Welcome, Lata! Your appointment has been booked under Repair Order (RO) R02401012."
                        android:textColor="@color/color_kia_black"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Messages list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerMessages"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="16dp"
                android:layout_weight="1" />
            <!-- Bottom unified container -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:backgroundTint="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Quick Replies (inside same box) -->
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingStart="12dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="4dp"
                        android:scrollbars="none">

                        <LinearLayout
                            android:id="@+id/quickReplyContainerTablet"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal" />
                    </HorizontalScrollView>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/light_gray_bg" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:padding="8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/edtMessageTablet"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="Text here"
                            android:textSize="15sp"
                            android:textColor="@color/black"
                            android:gravity="center_vertical"
                            />

                        <ImageView
                            android:id="@+id/imgAttachmentTablet"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginStart="8dp"
                            android:src="@drawable/ic_attach"
                            app:tint="@color/light_gray_bg" />

                        <LinearLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:id="@+id/recordLayout"
                            android:layout_marginStart="8dp"
                            android:gravity="center"
                          >

                            <ImageView
                                android:id="@+id/imgrecordTablet"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@drawable/bg_record_button"
                               />
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="40dp"
                            android:id="@+id/sendLayout"
                            android:layout_height="40dp"
                            android:layout_marginStart="8dp"
                            android:visibility="gone"

                            android:gravity="center"
                            >

                            <ImageView
                                android:id="@+id/imgSendTablet"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@drawable/bg_send_button"
                                />
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>

