<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="FloatingDialogStyle" parent="Theme.MaterialComponents.Light.Dialog">
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>


    <style name="PageNumberStyle">
        <item name="android:layout_width">32dp</item>
        <item name="android:layout_height">32dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">#444444</item>
    </style>

    <style name="PageNumberStyleSelected">
        <item name="android:layout_width">32dp</item>
        <item name="android:layout_height">32dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:background">@drawable/bg_page_selected</item>
    </style>

    <style name="CardShapeoutgoing">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">@dimen/_8sdp</item>
        <item name="cornerSizeTopRight">0dp</item>
        <item name="cornerSizeBottomLeft">@dimen/_8sdp</item>
        <item name="cornerSizeBottomRight">@dimen/_8sdp</item>
    </style>

    <style name="CardShapeicoming">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">0dp</item>
        <item name="cornerSizeTopRight">@dimen/_8sdp</item>
        <item name="cornerSizeBottomLeft">@dimen/_8sdp</item>
        <item name="cornerSizeBottomRight">@dimen/_8sdp</item>
    </style>

</resources>