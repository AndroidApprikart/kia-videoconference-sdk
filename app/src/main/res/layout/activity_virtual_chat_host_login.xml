<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Virtual Chat Login (Host App)"
        android:textSize="20sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/etHostUsername"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="Username / Name" />

    <EditText
        android:id="@+id/etHostUniqueId"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="Unique Id" />

    <EditText
        android:id="@+id/etHostRole"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="Role (e.g. service_advisor)" />

    <EditText
        android:id="@+id/etHostDealerCode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="Dealer Code" />

    <Button
        android:id="@+id/btnHostLoginToSdk"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Login and Open SDK" />

</LinearLayout>
